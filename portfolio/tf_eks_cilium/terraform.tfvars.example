aws_region         = "us-east-1"
project_name       = "demo"
environment        = "dev"
cluster_version    = "1.34"

vpc_cidr        = "10.0.0.0/16"
public_subnets  = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnets = ["10.0.11.0/24", "10.0.12.0/24"]

node_instance_types = ["t3.medium"]
node_desired_size   = 2
node_min_size       = 2
node_max_size       = 2

create_bastion         = true
bastion_instance_type  = "t3.micro"
bastion_allowed_cidrs  = ["YOUR_PUBLIC_IP/32"]
bastion_key_name       = null
bastion_public_key_path = "~/.ssh/id_rsa.pub"

# bastion_ami_id = "ami-xxxxxxxx"

tags = {
  Owner = "platform-team"
}

istio_enabled              = true
istio_version              = "1.29.1"
istio_ingress_service_type = "LoadBalancer"

istio_ingress_annotations = {
  # "service.beta.kubernetes.io/aws-load-balancer-type" = "nlb"
}