Step 1: Istio 기본 인프라 구축
먼저 Istio의 뇌(Istiod)와 입구(Gateway)를 설치합니다.

Bash


kubectl create namespace istio-system
kubectl create namespace monitoring
kubectl label namespace istio-system istio-injection=disabled
kubectl label namespace dev istio-injection=enabled

# MinIO (객체 저장소)
helm show values minio/minio > minio-values.yaml

# Mimir (Metrics) - 분산형이므로 리소스가 많으니 주의깊게 확인 필요
helm show values grafana/mimir-distributed > 

# Loki (Logs)
helm show values grafana/loki > loki-values.yaml

# Tempo (Traces)
helm show values grafana/tempo > tempo-values.yaml

# Grafana (Visualization)
helm show values grafana/grafana > grafana-values.yaml


# Repo 추가 및 업데이트
helm repo add istio https://istio-release.storage.googleapis.com/charts
helm repo update


# 1. Base (CRDs)
helm install istio-base istio/base -n istio-system --create-namespace

# 2. Istiod (Control Plane)
# Envoy가 로그와 트레이스를 외부로 보낼 수 있도록 meshConfig 설정 추가 권장
helm install istiod istio/istiod -n istio-system --wait

# 3. Ingress Gateway
helm install istio-ingress istio/gateway -n istio-ingress --create-namespace
kubectl port-forward -n istio-ingress svc/istio-ingress 8080:80


Step 2: LGTM 스택 설치 (Helm)
Grafana Labs의 차트를 사용하여 통합 설치합니다. (실무에선 각 컴포넌트를 분리하지만, 학습용으로는 lgtm-distributed나 개별 차트의 싱글 모드를 씁니다.)

Bash

# 1. Mimir (Metrics - Prometheus 대체/확장)
helm install mimir grafana/mimir-distributed -n monitoring --values ./mimir/mimir-values.yaml
helm upgrade --install mimir grafana/mimir-distributed \
  -n monitoring \
  --values ./mimir/mimir-values.yaml

# 2. Loki (Logs)
helm install loki grafana/loki -n monitoring --set loki.auth_enabled=false

# 경량모드
helm install loki grafana/loki-stack \
  --namespace monitoring \
  --set loki.persistence.enabled=false \
  --set loki.replicas=1 \
  --set promtail.enabled=true \
  --set grafana.enabled=false

## 실행 순서가 로키 먼저 실행되고 프롬테일 실행되야됨 
## 프롬테일 먼저실행되면 에러남 

loki:
  storage:
    type: s3
    s3:
      endpoint: minio.monitoring.svc.cluster.local:9000
      accessKeyId: admin
      secretAccessKey: password123
      bucketNames:
        chunks: loki-data

# 3. Tempo (Traces - Jaeger 대체)
helm install tempo grafana/tempo -n monitoring
helm install tempo grafana/tempo -n monitoring --values ./tempo/tempo-values.yaml

# 4. Grafana (Visualization)
helm repo add grafana https://grafana.github.io/helm-charts
helm repo update
helm install grafana grafana/grafana -n monitoring \
  --set adminPassword='admin' \
  --set service.type=LoadBalancer

kubectl port-forward svc/grafana -n monitoring 3000:80


Step 3: Istio와 LGTM 연결 설정
Istio가 수집한 데이터를 LGTM으로 쏘도록 설정합니다. Telemetry API를 활용합니다.

# istio-telemetry.yaml
apiVersion: telemetry.istio.io/v1alpha1
kind: Telemetry
metadata:
  name: mesh-default
  namespace: istio-system
spec:
  accessLogging:
    - providers:
        - name: envoy # Loki로 로그 전송 (Envoy 기본 로그)
  tracing:
    - providers:
        - name: zipkin # Tempo는 Zipkin/OTLP 포맷을 수용함
      randomSamplingPercentage: 100
kubectl apply -f istio-telemetry.yaml

# 키알리 설정 그라파나 연동

# 키알리 설치

helm repo add kiali https://kiali.org/helm-charts
helm repo update

helm upgrade --install kiali-server kiali/kiali-server -n istio-system \
  --set auth.strategy="anonymous" \
  --set external_services.prometheus.url="http://mimir-gateway.monitoring.svc.cluster.local:80/prometheus" \
  --set external_services.grafana.enabled=true \
  --set external_services.grafana.external_url="http://localhost:3000" \
  --set external_services.tracing.enabled=true \
  --set external_services.tracing.provider="tempo" \
  --set external_services.tracing.url="http://tempo.monitoring.svc.cluster.local:3200/tempo"  \
  --set external_services.grafana.internal_url="http://grafana.monitoring.svc.cluster.local:80"


external_services:
  grafana:
    enabled: true
    url: "http://<맥북-로컬-IP>:3000" # 실제 접속할 Grafana 주소
    in_cluster_url: "http://grafana.monitoring.svc.cluster.local:3000"
    dashboards:
      - name: "Istio Service Dashboard"
  tracing:
    enabled: true
    provider: "tempo" # 또는 "jaeger" (Tempo는 Jaeger API와 호환됨)
    url: "http://<맥북-로컬-IP>:32000" # Tempo/Grafana 트레이스 주소
    in_cluster_url: "http://tempo.monitoring.svc.cluster.local:3100"


